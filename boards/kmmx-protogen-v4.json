{
    "build": {
        "arduino": {
            "ldscript": "esp32s3_out.ld",
            "memory_type": "qio_opi"
        },
        "core": "esp32",
        "extra_flags": [
            "-DARDUINO_ESP32S3_DEV",
            "-DARDUINO_USB_MODE=1",
            "-DARDUINO_RUNNING_CORE=1",
            "-DARDUINO_EVENT_RUNNING_CORE=1",
            "-DBOARD_HAS_PSRAM",
            "-DBOARD_KMMX_V4=1"
        ],
        "f_cpu": "240000000L",
        "f_flash": "80000000L",
        "flash_mode": "qio",
        "hwids": [
            [
                "0x303A",
                "0x1001"
            ]
        ],
        "mcu": "esp32s3",
        "variant": "esp32s3",
        "psram_type": "opi"
    },
    "connectivity": [
        "wifi",
        "bluetooth"
    ],
    "debug": {
        "default_tool": "esp-builtin",
        "onboard_tools": [
            "esp-builtin"
        ],
        "openocd_target": "esp32s3.cfg"
    },
    "frameworks": [
        "arduino",
        "espidf"
    ],
    "name": "Espressif ESP32-S3-DevKitC-1-N16R8 (16 MB QD, 8MB PSRAM)",
    "upload": {
        "flash_size": "16MB",
        "maximum_ram_size": 8519680,
        "maximum_size": 16777216,
        "require_upload_port": true,
        "speed": 1500000,
        "use_1200bps_touch": true,
        "wait_for_upload_port": true
    },
    "url": "https://docs.espressif.com/projects/esp-idf/en/latest/esp32s3/hw-reference/esp32s3/user-guide-devkitc-1.html",
    "vendor": "Espressif"
}
